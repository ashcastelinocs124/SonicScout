{
  "name": "sonicscout",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "test": "vitest run",
    "dev": "concurrently -n api,web -c blue,magenta \"tsx watch src/index.ts\" \"npm --prefix web run dev\"",
    "build": "tsc -p tsconfig.json && mkdir -p dist/db && cp src/db/schema.sql dist/db/schema.sql && npm --prefix web run build",
    "start": "node dist/index.js",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@mendable/firecrawl-js": "^4.20.1",
