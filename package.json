    "bullmq": "^5.76.2",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "openai": "^6.35.0",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.1",
    "undici": "^8.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/supertest": "^7.2.0",
    "concurrently": "^9.2.1",
    "msw": "^2.13.6",
